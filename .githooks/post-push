#!/bin/bash

set -e

PROJECT_NAME=$(basename "$(git rev-parse --show-toplevel)")
ONEDRIVE_ROOT="$HOME/OneDrive/git-remotes"
BUNDLE_DIR="$ONEDRIVE_ROOT/bundles"
LOCK_DIR="$ONEDRIVE_ROOT/locks"

BUNDLE_FILE="$BUNDLE_DIR/$PROJECT_NAME.bundle"
LOCK_FILE="$LOCK_DIR/$PROJECT_NAME.lock"

mkdir -p "$BUNDLE_DIR" "$LOCK_DIR"

echo "[hook] post-push triggered for $PROJECT_NAME"

# -----------------------------
# 1. Wait for previous sync lock
# -----------------------------
MAX_WAIT=60   # seconds
WAITED=0

while [ -f "$LOCK_FILE" ]; do
  if [ "$WAITED" -ge "$MAX_WAIT" ]; then
    echo "[hook] timeout waiting for previous sync, skipping bundle"
    exit 0
  fi
  echo "[hook] waiting for previous sync... ($WAITED s)"
  sleep 2
  WAITED=$((WAITED+2))
done

# Create lock
touch "$LOCK_FILE"

# Ensure lock cleanup on exit
trap "rm -f '$LOCK_FILE'" EXIT

# -----------------------------
# 2. Check if HEAD changed
# -----------------------------
NEW_HEAD=$(git rev-parse HEAD)

if [ -f "$BUNDLE_FILE.head" ]; then
  OLD_HEAD=$(cat "$BUNDLE_FILE.head")
else
  OLD_HEAD=""
fi

if [ "$NEW_HEAD" = "$OLD_HEAD" ]; then
  echo "[hook] no new commits, skipping bundle"
  exit 0
fi

# -----------------------------
# 3. Create new bundle safely
# -----------------------------
TMP_BUNDLE="$BUNDLE_FILE.tmp"

echo "[hook] creating bundle..."
git bundle create "$TMP_BUNDLE" --all

# Atomic replace
mv "$TMP_BUNDLE" "$BUNDLE_FILE"

# Save HEAD
echo "$NEW_HEAD" > "$BUNDLE_FILE.head"

# -----------------------------
# 4. Rotate backups (keep last 3)
# -----------------------------
TIMESTAMP=$(date +"%Y%m%d-%H%M%S")
cp "$BUNDLE_FILE" "$BUNDLE_DIR/$PROJECT_NAME-$TIMESTAMP.bundle"

ls -t "$BUNDLE_DIR"/$PROJECT_NAME-*.bundle 2>/dev/null | tail -n +4 | xargs -r rm --

echo "[hook] bundle updated successfully"
